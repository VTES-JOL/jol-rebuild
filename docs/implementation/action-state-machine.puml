@startuml
!pragma layout smetana
top to bottom direction

skinparam nodesep 8
skinparam ranksep 10

skinparam state {
    BackgroundColor<<window>> #EAF3FF
    BorderColor<<window>> #2F6FA3
    BackgroundColor<<decision>> #FFF7E6
    BorderColor<<decision>> #A36B00
    BackgroundColor<<automatic>> #E6FFF7
    BorderColor<<automatic>> #00A36B
}

legend right
  |= Color |= Meaning |
  |<#EAF3FF> Window | players may play legal cards/effects |
  |<#FFF7E6> Decision | player choice, table discussion, or non-card polling |
  |<#E6FFF7> Automatic | automatic rules/mechanical resolution |
endlegend

[*] --> Idle
Idle : Empty enforced-mode action state
Idle : no PendingActionState
Idle : no CombatState
Idle : no ReferendumState
Idle : no ActiveTimingWindow

note top of Idle
  Entry point:
  empty action state
end note

Idle --> BuildPendingAction : DeclareAction or card ability

state "Play Card" as CardPlayWorkflow{
    state "CARD_AS_PLAYED" as CARD_AS_PLAYED <<window>>
    state "Replacement Check" as CardPlayReplace <<automatic>>
    state "Action Card Limbo" as ActionCardLimbo <<automatic>>
    state "Pay Cost" as CardPayCost <<automatic>>
    state "Resolve Card Effect" as CardResolveEffect <<automatic>>
    state "Move to Destination" as CardDestination <<automatic>>

    CARD_AS_PLAYED : eg. Direct Intervention, Wash, Sudden Reversal
    ActionCardLimbo : action cards remain pending until action resolution
    CardPayCost : non-action cards pay cost even if canceled
    CardPayCost : action cards pay only at action resolution
    CardDestination : ash heap, play area, or attachment
    CardPlayReplace : draw if canceled
    CardPlayReplace : draw unless delayed by card text
    CardPlayReplace : otherwise register delayed replacement
    CardResolveEffect : apply printed mode/effect text
    CardResolveEffect : create nested workflows if needed

    [*] --> CARD_AS_PLAYED : card declared from a playable region
    CARD_AS_PLAYED --> CardPlayReplace : canceled
    CARD_AS_PLAYED --> CardPlayReplace : all pass
    CardPlayReplace --> [*] : canceled action card or cost waived
    CardPlayReplace --> CardPayCost : canceled non-action card, replacement handled
    CardPlayReplace --> ActionCardLimbo : action card, replacement handled
    CardPlayReplace --> CardPayCost : non-action card, replacement handled
    ActionCardLimbo --> [*]
    CardPayCost --> [*] : canceled non-action card, no effect
    CardPayCost --> CardResolveEffect : not canceled
    CardResolveEffect --> CardDestination
    CardDestination --> [*]
}

note top of CardPlayWorkflow
  Any card played inside any timing window runs this
  nested workflow. The enclosing action/combat/referendum
  window determines whether the card is legal to play.
end note

state "How To Perform Actions\n(Detailed Play Guide)" as PerformActionWorkflow {
    state "Declaration" as BuildPendingAction <<decision>>
    state "Play Action Card" as PlayActionCard <<automatic>>
    state "ACTION_AS_ANNOUNCED" as ACTION_AS_ANNOUNCED <<window>>
    state "ACTION_DURING_ACTION" as ACTION_DURING_ACTION <<window>>
    state "ACTION_BLOCK_ATTEMPT" as ACTION_BLOCK_ATTEMPT <<window>>
    state "ACTION_STEALTH_INTERCEPT" as ACTION_STEALTH_INTERCEPT <<window>>
    state "ACTION_BLOCKS_DECLINED" as ACTION_BLOCKS_DECLINED <<window>>
    state "ACTION_BLOCK_RESOLUTION_PRE_COMBAT" as ACTION_BLOCK_RESOLUTION_PRE_COMBAT <<window>>
    state "Run Combat\nsubworkflow" as RunCombatWorkflow <<automatic>>
    state "ACTION_CONTINUING" as ACTION_CONTINUING <<window>>
    state "Complete Action" as CompleteAction <<automatic>>
    state "Run Referendum\nsubworkflow" as RunReferendumWorkflow <<automatic>>
    state "Run Diablerie\nsubworkflow" as RunDiablerieWorkflow <<automatic>>
    state "Run Blood Hunt\nsubworkflow" as RunBloodHuntWorkflow <<automatic>>
    state "Pay Action Cost" as PayActionCost <<automatic>>
    state "ApplyActionEffect" as ApplyActionEffect <<automatic>>
    state "ACTION_AFTER_RESOLUTION" as ACTION_AFTER_RESOLUTION <<window>>
    state "Clear Action State" as ClearActionState <<automatic>>

    BuildPendingAction : Declare all targets, modes, cost
    PlayActionCard : run CardPlayWorkflow
    PlayActionCard : only for action cards from hand
    ACTION_AS_ANNOUNCED : eg. Seduction, Day Operation, Car Bomb
    ACTION_DURING_ACTION : eg. Conditioning
    ACTION_BLOCK_ATTEMPT : eg. Eagle's Sight
    ACTION_STEALTH_INTERCEPT : eg. Lost in Crowds, Precognition
    ACTION_BLOCKS_DECLINED : eg. Deflection, Threats
    ACTION_BLOCK_RESOLUTION_PRE_COMBAT : eg. Massassi's Honor, Minor Irritation
    RunCombatWorkflow : enter CombatWorkflow side diagram
    RunCombatWorkflow : may run diablerie/blood hunt internally
    ACTION_CONTINUING : eg. Form of Mist
    ACTION_CONTINUING : block cycle resumes after combat
    ACTION_CONTINUING : stealth/intercept modifiers persist
    CompleteAction : action reaches resolution
    CompleteAction : NRA locks before cost
    PayActionCost : pay as much cost as possible
    PayActionCost : fizzle if full cost unpaid or targets invalid
    RunReferendumWorkflow : enter PoliticalReferendum side diagram
    RunDiablerieWorkflow : enter DiablerieWorkflow side diagram
    RunBloodHuntWorkflow : enter BloodHuntWorkflow side diagram
    ApplyActionEffect : resolve by ActionType
    ApplyActionEffect : bleed, hunt, equip, recruit, rescue, custom
    ACTION_AFTER_RESOLUTION : eg. Freak Drive
    ClearActionState : clear PendingActionState
    ClearActionState : close active action timing window
    ClearActionState : return to Idle

    BuildPendingAction --> PlayActionCard : action card from hand
    BuildPendingAction --> ACTION_AS_ANNOUNCED : basic action or in-play ability
    PlayActionCard --> ClearActionState : canceled
    PlayActionCard --> ACTION_AS_ANNOUNCED : card not canceled
    ACTION_AS_ANNOUNCED --> ACTION_DURING_ACTION : all pass
    ACTION_DURING_ACTION --> ACTION_BLOCK_ATTEMPT : block declared
    ACTION_BLOCK_ATTEMPT --> ACTION_STEALTH_INTERCEPT : stealth/intercept needed
    ACTION_STEALTH_INTERCEPT --> ACTION_DURING_ACTION : failed block attempt
    ACTION_DURING_ACTION --> ACTION_BLOCKS_DECLINED : all eligible Methuselahs decline
    ACTION_BLOCKS_DECLINED --> ACTION_DURING_ACTION : target changes or redirect
    ACTION_BLOCK_ATTEMPT --> ACTION_BLOCK_RESOLUTION_PRE_COMBAT : block succeeds
    ACTION_STEALTH_INTERCEPT --> ACTION_BLOCK_RESOLUTION_PRE_COMBAT : block succeeds
    ACTION_BLOCKS_DECLINED --> CompleteAction : all pass, no block
    ACTION_BLOCK_RESOLUTION_PRE_COMBAT --> RunCombatWorkflow : combat not canceled or replaced
    ACTION_BLOCK_RESOLUTION_PRE_COMBAT --> ACTION_CONTINUING : block resolution continues action
    ACTION_BLOCK_RESOLUTION_PRE_COMBAT --> ACTION_AFTER_RESOLUTION : block/action ends without combat
    RunCombatWorkflow --> ACTION_CONTINUING : continue-the-action effect
    RunCombatWorkflow --> ACTION_AFTER_RESOLUTION : no continuation
    ACTION_CONTINUING --> ACTION_DURING_ACTION : reopen block attempts
    CompleteAction --> PayActionCost : all unblocked actions
    PayActionCost --> RunReferendumWorkflow : political action
    PayActionCost --> RunDiablerieWorkflow : diablerie action or effect
    PayActionCost --> ApplyActionEffect : bleed, hunt, equip, recruit, rescue, custom
    PayActionCost --> ACTION_AFTER_RESOLUTION : fizzles, no action effect
    RunReferendumWorkflow --> ACTION_AFTER_RESOLUTION
    RunDiablerieWorkflow --> RunBloodHuntWorkflow : successful diablerie
    RunDiablerieWorkflow --> ACTION_AFTER_RESOLUTION : canceled/no blood hunt
    RunBloodHuntWorkflow --> ACTION_AFTER_RESOLUTION : enclosing action remains
    RunBloodHuntWorkflow --> ClearActionState : no enclosing action remains
    ApplyActionEffect --> ACTION_AFTER_RESOLUTION
    ACTION_AFTER_RESOLUTION --> ClearActionState : all pass
}

note top of PerformActionWorkflow
  This is the Detailed Play Guide "How to Perform Actions"
  workflow. Nodes named "Run ... subworkflow" are handoff
  points to the side diagrams, not inline expansions.
end note

state "Combat" as CombatWorkflow {
    state "COMBAT_BEFORE_RANGE" as COMBAT_BEFORE_RANGE <<window>>
    state "COMBAT_DETERMINE_RANGE" as COMBAT_DETERMINE_RANGE <<window>>
    state "COMBAT_BEFORE_STRIKES" as COMBAT_BEFORE_STRIKES <<window>>
    state "COMBAT_STRIKE_DECLARATION" as COMBAT_STRIKE_DECLARATION <<window>>
    state "COMBAT_BEFORE_STRIKE_RESOLUTION" as COMBAT_BEFORE_STRIKE_RESOLUTION <<window>>
    state "Resolve Strikes" as ResolveDeclaredStrikes <<automatic>>
    state "COMBAT_DAMAGE_PREVENTION" as COMBAT_DAMAGE_PREVENTION <<window>>
    state "COMBAT_DAMAGE_RESOLUTION" as COMBAT_DAMAGE_RESOLUTION <<window>>
    state "COMBAT_WOULD_GO_TO_TORPOR" as COMBAT_WOULD_GO_TO_TORPOR <<window>>
    state "COMBAT_WOULD_BE_BURNED" as COMBAT_WOULD_BE_BURNED <<window>>
    state "Run Diablerie/Blood Hunt\nsubworkflows" as RunCombatDiablerieWorkflow <<automatic>>
    state "Commit Combat Result" as CommitCombatResult <<automatic>>
    state "COMBAT_ADDITIONAL_STRIKE" as COMBAT_ADDITIONAL_STRIKE <<window>>
    state "COMBAT_PRESS_STEP" as COMBAT_PRESS_STEP <<window>>
    state "COMBAT_END_OF_ROUND" as COMBAT_END_OF_ROUND <<window>>
    state "COMBAT_WOULD_END" as COMBAT_WOULD_END <<window>>
    state "COMBAT_ENDS" as COMBAT_ENDS <<automatic>>
    state "COMBAT_AFTER_ENDS" as COMBAT_AFTER_ENDS <<window>>

    COMBAT_BEFORE_RANGE : eg. Carrion Crows
    COMBAT_DETERMINE_RANGE : eg. Flash
    COMBAT_BEFORE_STRIKES : eg. Immortal Grapple
    COMBAT_STRIKE_DECLARATION : eg. Theft of Vitae
    COMBAT_DAMAGE_PREVENTION : eg. Forearm Block
    COMBAT_BEFORE_STRIKE_RESOLUTION : eg. Blood to Water
    COMBAT_WOULD_GO_TO_TORPOR : eg. Amaranth
    COMBAT_WOULD_BE_BURNED : eg. Reform Body
    COMBAT_ADDITIONAL_STRIKE : eg. Blur
    COMBAT_PRESS_STEP : eg. Psyche!
    COMBAT_END_OF_ROUND : eg. Taste of Vitae
    COMBAT_WOULD_END: eg. Telepathic Tracking
    COMBAT_DAMAGE_RESOLUTION: eg. Twisting the Knife
    COMBAT_ENDS: //Effect: combat is ending//
    COMBAT_AFTER_ENDS: eg. Form of Mist
    RunCombatDiablerieWorkflow: enter DiablerieWorkflow side diagram
    RunCombatDiablerieWorkflow: enter BloodHuntWorkflow if diablerie succeeds
    ResolveDeclaredStrikes: * Check strike order
    ResolveDeclaredStrikes: * Assign strike effects
    ResolveDeclaredStrikes: * Apply non-damage effects, or queue them
    CommitCombatResult: * Move to torpor / ash heap if needed
    CommitCombatResult: * Clear pending damage
    CommitCombatResult: * Update life/blood counters

    [*] --> COMBAT_BEFORE_RANGE
    COMBAT_BEFORE_RANGE --> COMBAT_DETERMINE_RANGE : all pass
    COMBAT_DETERMINE_RANGE --> COMBAT_BEFORE_STRIKES : range set
    COMBAT_BEFORE_STRIKES --> COMBAT_STRIKE_DECLARATION : all pass
    COMBAT_STRIKE_DECLARATION --> COMBAT_BEFORE_STRIKE_RESOLUTION
    COMBAT_BEFORE_STRIKE_RESOLUTION --> ResolveDeclaredStrikes
    ResolveDeclaredStrikes --> COMBAT_DAMAGE_PREVENTION
    COMBAT_DAMAGE_PREVENTION --> COMBAT_DAMAGE_RESOLUTION
    COMBAT_DAMAGE_RESOLUTION --> COMBAT_WOULD_GO_TO_TORPOR : vampire would go to torpor
    COMBAT_DAMAGE_RESOLUTION --> COMBAT_WOULD_BE_BURNED : minion would burn
    COMBAT_DAMAGE_RESOLUTION --> CommitCombatResult : no replacement hook
    COMBAT_WOULD_GO_TO_TORPOR --> RunCombatDiablerieWorkflow : diablerie replaces torpor
    COMBAT_WOULD_GO_TO_TORPOR --> CommitCombatResult : result not replaced
    COMBAT_WOULD_BE_BURNED --> CommitCombatResult : result not replaced
    RunCombatDiablerieWorkflow --> COMBAT_END_OF_ROUND : subworkflows complete
    RunCombatDiablerieWorkflow --> CommitCombatResult : diablerie canceled
    CommitCombatResult --> COMBAT_ADDITIONAL_STRIKE : combatants still ready
    COMBAT_ADDITIONAL_STRIKE --> COMBAT_STRIKE_DECLARATION : additional strike gained/used
    COMBAT_ADDITIONAL_STRIKE --> COMBAT_PRESS_STEP : all pass, no additional strike
    COMBAT_PRESS_STEP --> COMBAT_BEFORE_RANGE : press to continue
    COMBAT_PRESS_STEP --> COMBAT_END_OF_ROUND : no new round
    ResolveDeclaredStrikes --> COMBAT_END_OF_ROUND : combat ends strike
    CommitCombatResult --> COMBAT_END_OF_ROUND : combatant no longer ready
    COMBAT_END_OF_ROUND --> COMBAT_WOULD_END
    COMBAT_WOULD_END --> COMBAT_ENDS
    COMBAT_ENDS --> COMBAT_AFTER_ENDS
    COMBAT_AFTER_ENDS --> [*] : combat-ending hooks complete
}

state "Political Referendum" as PoliticalReferendum {
    state "REFERENDUM_CHOOSE_TERMS" as REFERENDUM_CHOOSE_TERMS <<decision>>
    state "REFERENDUM_BEFORE_VOTES" as REFERENDUM_BEFORE_VOTES <<window>>
    state "REFERENDUM_POLLING" as REFERENDUM_POLLING <<window>>
    state "REFERENDUM_RESOLUTION" as REFERENDUM_RESOLUTION <<automatic>>
    state "REFERENDUM_AFTER_RESOLUTION" as REFERENDUM_AFTER_RESOLUTION <<window>>

    REFERENDUM_CHOOSE_TERMS : acting controller chooses terms
    REFERENDUM_CHOOSE_TERMS : targets/options fixed for polling
    REFERENDUM_BEFORE_VOTES : eg. Akunanse Kholo, Poison Pill
    REFERENDUM_POLLING : eg. Absolute Tyranny
    REFERENDUM_POLLING : card/effect polling window
    REFERENDUM_AFTER_RESOLUTION : eg. Voter Captivation
    REFERENDUM_RESOLUTION: eg. //Effect: Domain Challenge//

    [*] --> REFERENDUM_CHOOSE_TERMS
    REFERENDUM_CHOOSE_TERMS --> REFERENDUM_BEFORE_VOTES
    REFERENDUM_BEFORE_VOTES --> REFERENDUM_POLLING
    REFERENDUM_POLLING --> REFERENDUM_RESOLUTION
    REFERENDUM_RESOLUTION --> REFERENDUM_AFTER_RESOLUTION
    REFERENDUM_AFTER_RESOLUTION --> [*]
}

state "Diablerie" as DiablerieWorkflow {
    state "DIABLERIE_CANCEL_OR_REPLACE" as DIABLERIE_CANCEL_OR_REPLACE <<window>>
    state "Diablerie Blood Transfer" as DiablerieBloodTransfer <<automatic>>
    state "Choose Equipment" as DiablerieEquipmentChoice <<decision>>
    state "Burn Victim" as DiablerieBurnVictim <<automatic>>
    state "Discipline Search" as DiablerieDisciplineSearch <<decision>>
    state "DIABLERIE_AFTER_SUCCESS" as DIABLERIE_AFTER_SUCCESS <<window>>
    state "TROPHY_AWARD_BEFORE_BLOOD_HUNT" as TROPHY_AWARD_BEFORE_BLOOD_HUNT <<decision>>
    state "Run Blood Hunt\nsubworkflow" as RunBloodHuntAfterDiablerie <<automatic>>

    DIABLERIE_AFTER_SUCCESS: eg. Rebirth
    TROPHY_AWARD_BEFORE_BLOOD_HUNT: eg. Trophy: Diablerie
    DIABLERIE_CANCEL_OR_REPLACE: eg. Crimson Fury, The Deadliest Sin
    DIABLERIE_CANCEL_OR_REPLACE: diablerie attempt has begun
    DiablerieEquipmentChoice: choose equipment to take
    DiablerieEquipmentChoice: leave unchosen equipment on victim
    DiablerieBurnVictim: move victim to ash heap
    DiablerieBurnVictim: burn remaining attached cards/counters
    DiablerieDisciplineSearch: optional if victim capacity is higher
    DiablerieDisciplineSearch: search hand/library/ash heap
    RunBloodHuntAfterDiablerie: enter BloodHuntWorkflow side diagram

    [*] --> DIABLERIE_CANCEL_OR_REPLACE : diablerie attempt begins
    DIABLERIE_CANCEL_OR_REPLACE --> [*] : canceled
    DIABLERIE_CANCEL_OR_REPLACE --> DiablerieBloodTransfer : not canceled
    DiablerieBloodTransfer --> DiablerieEquipmentChoice
    DiablerieEquipmentChoice --> DiablerieBurnVictim
    DiablerieBurnVictim --> DiablerieDisciplineSearch
    DiablerieDisciplineSearch --> DIABLERIE_AFTER_SUCCESS
    DIABLERIE_AFTER_SUCCESS --> TROPHY_AWARD_BEFORE_BLOOD_HUNT
    TROPHY_AWARD_BEFORE_BLOOD_HUNT --> RunBloodHuntAfterDiablerie
    RunBloodHuntAfterDiablerie --> [*]
}

state "Blood Hunt" as BloodHuntWorkflow {
    state "BLOOD_HUNT_POLLING\n(vote sources only)" as BLOOD_HUNT_POLLING <<decision>>
    state "BLOOD_HUNT_RESOLUTION" as BLOOD_HUNT_RESOLUTION <<automatic>>
    state "BLOOD_HUNT_WOULD_BURN_DIABLERIST" as BLOOD_HUNT_WOULD_BURN_DIABLERIST <<window>>
    state "Burn Diablerist" as BurnDiablerist <<automatic>>

    BLOOD_HUNT_POLLING : votes from table state
    BLOOD_HUNT_POLLING : political action card may be burned for a vote
    BLOOD_HUNT_POLLING : Edge may be burned for a vote
    BLOOD_HUNT_POLLING : no action modifiers or reactions
    BLOOD_HUNT_RESOLUTION : tally for/against votes
    BLOOD_HUNT_RESOLUTION : passes only if for > against
    BLOOD_HUNT_WOULD_BURN_DIABLERIST : eg. Lay Low, Absolution of the Diabolist
    BurnDiablerist : move diablerist to ash heap

    [*] --> BLOOD_HUNT_POLLING
    BLOOD_HUNT_POLLING --> BLOOD_HUNT_RESOLUTION
    BLOOD_HUNT_RESOLUTION --> BLOOD_HUNT_WOULD_BURN_DIABLERIST : passes
    BLOOD_HUNT_RESOLUTION --> [*] : fails
    BLOOD_HUNT_WOULD_BURN_DIABLERIST --> BurnDiablerist : all pass, no replacement
    BLOOD_HUNT_WOULD_BURN_DIABLERIST --> [*] : burn replaced/prevented
    BurnDiablerist --> [*]
}

PerformActionWorkflow -[hidden]down-> CardPlayWorkflow
PerformActionWorkflow -[hidden]down-> CombatWorkflow
PerformActionWorkflow -[hidden]down-> PoliticalReferendum
PerformActionWorkflow -[hidden]down-> DiablerieWorkflow
PerformActionWorkflow -[hidden]down-> BloodHuntWorkflow
@enduml
